#!/usr/bin/env bash
# Pre-commit hook — landlock-genprof.
#
# Activation (une fois par clone) :
#   git config core.hooksPath .githooks
#
# Voir aussi .githooks/commit-msg (validation de la convention de message,
# étape séparée car le message n'existe pas encore à ce stade du commit).
#
# Ne reproduit volontairement pas hack/check-kernel.sh ici : ce hook doit
# rester exécutable sur macOS/Windows (WSL) en plus de Linux, alors que la
# vérification kernel Landlock n'a de sens que sur la machine de dev Linux
# (voir HOW_TO_START.md §0). Cette vérification reste dans la CI et le
# workflow manuel de HOW_TO_START.md §2.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

echo "== pre-commit: gofmt =="
unformatted="$(gofmt -l .)"
if [ -n "$unformatted" ]; then
	echo "Fichiers non formatés :"
	echo "$unformatted"
	echo "Corrige avec: gofmt -w <fichier>"
	exit 1
fi

echo "== pre-commit: go vet =="
go vet ./...

echo "== pre-commit: go build =="
go build ./...

echo "== pre-commit: go test (couverture) =="
# Informatif uniquement : la plupart des packages sont encore des stubs
# sans aucun test (tracer, k8s, cmd) — pas de seuil bloquant sur le %.
go test -cover ./...

echo "pre-commit OK"
