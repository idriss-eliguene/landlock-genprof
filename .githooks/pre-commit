#!/usr/bin/env bash
# Pre-commit hook — landlock-genprof.
#
# Activation (once per clone):
#   git config core.hooksPath .githooks
#
# See also .githooks/commit-msg (commit message convention check, a
# separate hook stage since the message doesn't exist yet at this point).
#
# Deliberately does not reproduce hack/check-kernel.sh here: this hook must
# stay runnable on macOS/Windows (WSL) as well as Linux, whereas the
# Landlock kernel check only makes sense on the Linux dev machine (see
# HOW_TO_START.md §0). That check stays in CI and in the manual workflow
# from HOW_TO_START.md §2.
#
# Printed strings below (echo) are kept in French on purpose: this hook is
# activated and seen daily by French-speaking students per HOW_TO_START.md.
#
# go build/test below work on any OS, including this hook running from
# macOS/Windows: internal/tracer is split by build tag (trace_linux.go /
# trace_other.go) specifically so the Inspektor Gadget SDK's Linux-only
# code doesn't leak into what every other package needs to compile — see
# docs/architecture.md §3. If a future change to internal/tracer breaks
# `go build ./...` on non-Linux, that split is almost certainly what got
# violated (new Linux-only import added outside trace_linux.go).
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

echo "== pre-commit: gofmt =="
unformatted="$(gofmt -l .)"
if [ -n "$unformatted" ]; then
	echo "Fichiers non formatés :"
	echo "$unformatted"
	echo "Corrige avec: gofmt -w <fichier>"
	exit 1
fi

echo "== pre-commit: go vet =="
go vet ./...

echo "== pre-commit: go build =="
go build ./...

echo "== pre-commit: go test (couverture) =="
# Informational only, no blocking threshold on the percentage. internal/tracer
# and cmd have no unit tests: the former needs a real cluster with Inspektor
# Gadget deployed to test meaningfully, the latter is thin wiring around
# already-tested packages (internal/k8s, internal/policy).
go test -cover ./...

echo "pre-commit OK"
